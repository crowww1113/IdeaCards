<?xml version="1.0" encoding="utf-8"?>
<!-- 归档列表页布局：顶部导航栏 + 笔记列表
     柔和美学：燕麦背景、大圆角卡片、治愈蓝按钮 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:orientation="vertical"
    tools:context=".ArchiveActivity">

    <!-- ═══ 顶部导航栏 ═══ -->
    <!-- 横向布局：返回键 + 标题 + 提醒按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="12dp">

        <!-- 返回按钮：透明背景，视觉轻盈 -->
        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:src="@android:drawable/ic_menu_revert"
            android:scaleType="centerInside"
            android:tint="@color/text_primary" />

        <!-- 页面标题：深褐主文本 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="灵感归档"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- 导出 MD 按钮：柔粉背景、大圆角、无阴影 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/accent_pastel_pink"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/btn_export"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="导出 MD"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />

        </com.google.android.material.card.MaterialCardView>

        <!-- 提醒按钮：治愈蓝背景、大圆角、无阴影 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/accent_pastel_blue"
            app:strokeWidth="0dp">

            <TextView
                android:id="@+id/btn_remind"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="提醒我整理"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- ═══ 笔记列表区 ═══ -->
    <!-- 左右 margin=20dp，隐藏滚动条 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_archive_notes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="20dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

</LinearLayout>
