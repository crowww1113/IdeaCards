<?xml version="1.0" encoding="utf-8"?>
<!-- 归档笔记卡片：柔和美学
     MaterialCardView 圆角 20dp、极弱阴影、白底
     左侧治愈蓝装饰竖线 + 右侧内容区 -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/card_white"
    app:strokeWidth="0dp">

    <!-- 横向容器：复选框 + 装饰线 + 内容 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 多选复选框：默认隐藏，编辑模式下由 Adapter 控制显隐 -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cb_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:visibility="gone"
            app:buttonTint="@color/tag_highlight"
            app:useMaterialThemeColors="false" />

        <!-- 左侧装饰竖线：4dp 宽、治愈蓝、圆角 2dp -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/accent_pastel_blue" />

        <!-- 右侧内容区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <!-- 内容摘要：深褐主文本，最多 3 行 -->
            <TextView
                android:id="@+id/tv_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:lineSpacingExtra="4dp"
                android:maxLines="3"
                android:ellipsize="end"
                android:text="" />

            <!-- 底部信息行：时间 + 状态 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 时间戳：浅灰紫副文本 -->
                <TextView
                    android:id="@+id/tv_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="" />

                <!-- 状态标签：浅灰紫 -->
                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:text="" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
