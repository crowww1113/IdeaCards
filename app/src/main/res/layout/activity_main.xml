<?xml version="1.0" encoding="utf-8"?>
<!-- 主界面布局：顶部名言区 + 中间笔记列表 + 底部悬浮输入区
     柔和美学：燕麦色背景、圆角卡片、呼吸感留白 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- ═══ 顶部名言 + 归档（紧凑单行，跑马灯滚动） ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp">

        <!-- 每日一言：单行跑马灯 -->
        <TextView
            android:id="@+id/tv_quote"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:text="" />

        <!-- 归档入口：纯图标 -->
        <ImageView
            android:id="@+id/btn_archive"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_archive"
            android:contentDescription="归档" />

    </LinearLayout>

    <!-- ═══ 中间笔记列表 ═══ -->
    <!-- RecyclerView 撑满剩余空间，左右留白 12dp，隐藏滚动条 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_notes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="12dp"
        android:paddingBottom="20dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- ═══ 底部悬浮输入胶囊区 ═══ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/card_white"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp">

            <!-- 标签选择区：水平滑动的标签气泡 -->
            <HorizontalScrollView
                android:id="@+id/hsv_tags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:visibility="gone"
                android:layout_marginBottom="2dp">

                <LinearLayout
                    android:id="@+id/ll_tags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />

            </HorizontalScrollView>

            <!-- 输入行：标签按钮 + 输入框 + 发送按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 标签按钮：点击向输入框追加 # 号，方便用户手动输入标签 -->
                <TextView
                    android:id="@+id/btn_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="#"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/tag_highlight"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- OCR 识图按钮：从相册选图提取文字 -->
                <ImageView
                    android:id="@+id/btn_ocr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="6dp"
                    android:src="@drawable/ic_photo"
                    android:scaleType="centerInside"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="识图" />

                <!-- 输入框：无边框透明背景，与卡片融为一体 -->
                <EditText
                    android:id="@+id/et_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="写下你的想法..."
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:maxLines="3"
                    android:inputType="textMultiLine"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="12dp"
                    android:background="@android:color/transparent" />

                <!-- 发送按钮：治愈蓝背景胶囊形 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/accent_pastel_blue"
                    app:strokeWidth="0dp">

                    <TextView
                        android:id="@+id/btn_send"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="10dp"
                        android:text="发送"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary" />

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
